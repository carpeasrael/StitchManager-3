    <display_length compare="ge">768</display_length>
  </requires>

  <releases>
    <release version="26.3.3" date="2026-03-15">
      <description>
        <p>Security and stability audit fixes:</p>
        <ul>
          <li>Hardened path traversal checks across all file operations</li>
          <li>Removed unused SQL execute permission</li>
          <li>Added file size limits to prevent memory exhaustion</li>
          <li>Reduced version snapshot size threshold</li>
        </ul>
      </description>
    </release>
  </releases>
